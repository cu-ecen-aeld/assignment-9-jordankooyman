#!/bin/sh
# file: S98aesdchar
#
# Start/stop aesdchar kernel module and create device node
#
# Written using DeepSeek: https://chat.deepseek.com/share/4m9wymxypxs883oyy6, https://chat.deepseek.com/share/4vux06agxx62efx7rk
#

MODULE="aesdchar"
DEVICE="aesdchar"
MODE="666"

# Determine the group (wheel or staff) for permissions
if grep -q '^staff:' /etc/group 2>/dev/null; then
    GROUP="staff"
else
    GROUP="wheel"
fi

case "$1" in
    start)
        echo "Loading $MODULE kernel module"
        modprobe $MODULE || exit 1

        # Wait a moment for the module to register (optional)
        sleep 1

        # Get the major number from /proc/devices
        MAJOR=$(awk "\$2==\"$MODULE\" {print \$1}" /proc/devices)
        if [ -z "$MAJOR" ]; then
            echo "Failed to find major number for $MODULE"
            exit 1
        fi

        # Remove any stale node and create a new one
        rm -f /dev/${DEVICE}
        mknod /dev/${DEVICE} c $MAJOR 0

        # Set permissions
        chgrp $GROUP /dev/${DEVICE}
        chmod $MODE  /dev/${DEVICE}

        echo "$MODULE device node created at /dev/${DEVICE}"
        ;;
    stop)
        echo "Unloading $MODULE kernel module"
        rmmod $MODULE || exit 1

        # Remove the device node (optional, but clean)
        rm -f /dev/${DEVICE}
        ;;
    restart|reload)
        "$0" stop
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
esac

exit 0
